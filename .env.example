# Copier en `.env` puis renseigner.

# Base de données PostgreSQL (Neon recommandé pour Vercel).
# URL de connexion « pooled » depuis le dashboard Neon : https://console.neon.tech
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# Secret conservé si une authentification est réintroduite (actuellement désactivée
# pour la démo Vercel : chaque visiteur agit comme l'administrateur système).
AUTH_SECRET="change-me-in-production"

# Jeton Vercel Blob (stockage privé des documents GED). Généré automatiquement
# quand un store Blob est rattaché au projet Vercel ; pour le dev/seed local,
# récupérer le jeton dans le dashboard Vercel (Storage > Blob).
# Sans ce jeton, le seed insère des documents avec un chemin placeholder.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxx"
