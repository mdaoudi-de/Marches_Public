# Copier en `.env` puis ajuster si besoin.

# Base de données PostgreSQL (Neon). Récupérer l'URL de connexion (pooled)
# depuis le dashboard Neon : https://console.neon.tech
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# Secret de signature des jetons de session (à régénérer en production).
AUTH_SECRET="change-me-in-production"

# Jeton Vercel Blob (stockage des documents GED). Généré automatiquement par
# Vercel quand un store Blob est rattaché au projet ; pour le dev local,
# récupérer le jeton depuis le dashboard Vercel (Storage > Blob).
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxx"
